# Copy this file to .env on the server and fill real values.

IMAGE_TAG=latest
PORT=3000

POSTGRES_DB=workflow_studio
POSTGRES_USER=workflow_user
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql://workflow_user:replace-with-a-strong-database-password@workflow-postgres:5432/workflow_studio?schema=public

SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars
COOKIE_SECURE=false
FRONTEND_ORIGIN=http://8.130.32.43:8901
N8N_TIMEOUT_MS=60000
JSON_BODY_LIMIT=15mb
PUBLIC_BASE_URL=http://8.130.32.43:8901
UPLOADS_DIR=/app/storage/uploads
UPLOADS_PUBLIC_PATH=/uploads
MAX_REFERENCE_IMAGE_BYTES=3145728
MAX_REFERENCE_IMAGE_COUNT=3
MAX_REFERENCE_IMAGE_REQUESTS=30

ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=replace-with-initial-admin-password

XHS_START_WORKFLOW_URL=http://8.130.32.43:5678/webhook/start-workflows
XHS_STATUS_QUERY_URL=http://8.130.32.43:5678/webhook/lunxuns
XHS_USER_ACTION_URL=http://8.130.32.43:5678/webhook/user-actions
XHS_REGENERATE_IMAGE_URL=http://8.130.32.43:5678/webhook/user-actions

DOUYIN_START_WORKFLOW_URL=http://8.130.32.43:5678/webhook/douyinstart
DOUYIN_STATUS_QUERY_URL=http://8.130.32.43:5678/webhook/douyinchaxun
DOUYIN_DOWNLOAD_URL=http://8.130.32.43:5678/webhook/douyin-download
DOUYIN_USER_ACTION_URL=http://8.130.32.43:5678/webhook/douyinyhcz
DOUYIN_FRAME_ACTION_URL=http://your-n8n-host:5678/webhook/douyin-frame-action
DOUYIN_GENERATE_VIDEO_URL=http://your-n8n-host:5678/webhook/douyin-generate-video
DOUYIN_REGENERATE_VIDEO_URL=http://your-n8n-host:5678/webhook/douyin-regenerate-video